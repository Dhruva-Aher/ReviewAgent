# Required
GROQ_API_KEY= # Groq API key for LLM calls
GITHUB_TOKEN= # Personal access token (local dev only)

# GitHub App (production)
GITHUB_APP_ID= # GitHub App ID
GITHUB_APP_PRIVATE_KEY= # PEM key contents (newlines as \n)
GITHUB_WEBHOOK_SECRET= # Webhook secret for signature validation

# Behavior
MULTI_AGENT=true # Set to false to use single-agent fallback
CONFIDENCE_THRESHOLD=60 # Filter issues below this confidence score
APP_ENV=development # Set to production to enforce webhook signatures

# Infrastructure
REDIS_URL=redis://localhost:6379
DB_PATH=./data/beliefs.db
